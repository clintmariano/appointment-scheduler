# MongoDB Atlas Connection String
# Get this from MongoDB Atlas: https://cloud.mongodb.com
# 1. Create a free cluster
# 2. Click "Connect" > "Connect your application"
# 3. Copy the connection string and replace <password> with your password
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ehrdb?retryWrites=true&w=majority

# Server Port
PORT=3001
