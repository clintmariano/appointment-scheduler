# MongoDB Atlas Connection String
# Get this from MongoDB Atlas: https://cloud.mongodb.com
# 1. Create a free cluster
# 2. Click "Connect" > "Connect your application"
# 3. Copy the connection string and replace <password> with your password
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ehrdb?retryWrites=true&w=majority

# Server Port
PORT=3001

# Cloudflare R2 Configuration (optional - falls back to local storage if not set)
# Get these from Cloudflare dashboard: https://dash.cloudflare.com
# 1. Go to R2 > Overview > Manage R2 API Tokens
# 2. Create a new API token with Object Read & Write permissions
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Optional: Custom domain for public bucket access (e.g., https://images.yourdomain.com)
R2_PUBLIC_URL=

# Timezone Configuration (required for cloud deployment)
# Set to your clinic's timezone to ensure correct date/time handling
# Railway, Vercel, and other cloud providers default to UTC
TZ=Asia/Manila
